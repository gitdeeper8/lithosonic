# LITHO-SONIC Git Attributes

# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python
*.pyx text diff=python
*.pxd text diff=python
*.pyi text diff=python

# Documentation
*.md text diff=markdown
*.rst text diff=rst
*.txt text
*.ipynb text

# Config files
*.yml text
*.yaml text
*.json text
*.toml text
*.cfg text
*.ini text
*.conf text

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text
Dockerfile.dev text
*.dockerignore text

# Git
.gitattributes text
.gitignore text

# Data files
*.csv text
*.h5 binary
*.nc binary
*.hdf5 binary
*.npy binary
*.npz binary

# Models
*.h5 binary
*.pkl binary
*.joblib binary
*.pt binary
*.pth binary
*.onnx binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
*.ico binary

# Archives
*.tar.gz binary
*.zip binary
*.7z binary
*.bz2 binary
*.xz binary

# Logs
*.log text
